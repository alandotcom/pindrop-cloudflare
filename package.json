{
  "name": "pindrop-comments",
  "private": true,
  "type": "module",
  "bin": {
    "pindrop-comments": "bin/pindrop-comments.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "comments": "node bin/pindrop-comments.mjs",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir dist",
    "types": "wrangler types",
    "types:client": "tsc client/pindrop-comments.js --allowJs --declaration --emitDeclarationOnly --lib es2022,dom --target es2022 --module esnext --moduleResolution bundler --outDir client",
    "typecheck": "tsc --noEmit",
    "typecheck:client": "tsc client/pindrop-comments.js --allowJs --checkJs --noEmit --lib es2022,dom --target es2022 --module esnext --moduleResolution bundler",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:client": "node --test 'test/client/*.test.mjs'",
    "test:all": "vitest run && node --test 'test/client/*.test.mjs'",
    "smoke": "node scripts/smoke.mjs",
    "serve:demo": "bunx --bun serve . -l 3000"
  },
  "dependencies": {
    "partyserver": "^0.5.7"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.15",
    "@cloudflare/workers-types": "^4.20250604.0",
    "partysocket": "1.1.19",
    "pindrop.js": "0.1.28",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.100.0"
  }
}
